-- Toggle Button Creator Function
local function CreateToggle(name, configPath, pos)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.BackgroundColor3 = Config[configPath] and Color3.fromRGB(60, 180, 100) or Color3.fromRGB(180, 60, 60)
    btn.Text = name .. ": " .. (Config[configPath] and "ON" or "OFF")
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 14
    
    local btnCorner = Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        Config[configPath] = not Config[configPath]
        btn.Text = name .. ": " .. (Config[configPath] and "ON" or "OFF")
        btn.BackgroundColor3 = Config[configPath] and Color3.fromRGB(60, 180, 100) or Color3.fromRGB(180, 60, 60)
    end)
end

-- Create Menu Buttons (Fly is REMOVED)
