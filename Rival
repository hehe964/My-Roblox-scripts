-- // Menu Toggle Logic
UIS.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        _G.MenuVisible = not _G.MenuVisible
        MainFrame.Visible = _G.MenuVisible
    end
end)

-- // Target Finder for Rivals
local function GetClosestTarget()
    local target, closestDist = nil, _G.AimbotFOV
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            -- Team Check (Rivals specific check)
            if player.Team ~= LocalPlayer.Team then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
                    if dist < closestDist then
                        target = player.Character.Head
                        closestDist = dist
                    end
                end
            end
        end
    end
    return target
end

-- // Main Combat & Physics Loop
RunService.RenderStepped:Connect(function()
    -- Noclip (Ghost Mode)
    if _G.NoclipEnabled and LocalPlayer.Character then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    -- Aimbot Headlock
    if _G.AimbotEnabled then
        local target = GetClosestTarget()
        if target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end

    -- Rivals Optimized ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("RivalsESP")
            if _G.ESPEnabled and p.Team ~= LocalPlayer.Team then
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "RivalsESP"
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
                    highlight.Parent = p.Character
                end
            elseif highlight then
                highlight:Destroy()
            end
        end
    end
end)

-- // Rivals Wall Pierce (Raycast Bypass)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if _G.WallPierce and (method == "Raycast" or method == "FindPartOnRay") then
        -- This attempts to redirect Rivals' bullets towards players and ignore obstacles
        return oldNamecall(self, unpack(args))
    end
    return oldNamecall(self, ...)
end)

